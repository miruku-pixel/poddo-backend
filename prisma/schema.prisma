generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Outlet {
  id                      String                    @id @default(uuid())
  name                    String                    @unique
  addressLine             String
  city                    String
  state                   String
  postalCode              String
  country                 String
  phoneNumber             String?
  contactName             String?
  email                   String?
  createdAt               DateTime                  @default(now())
  billing                 Billing[]
  tables                  DiningTable[]
  foods                   Food[]
  Ingredient              Ingredient[]
  IngredientStockLog      IngredientStockLog[]
  orders                  Order[]
  OrderNumberCounter      OrderNumberCounter?
  OrderTypeDiscount       OrderTypeDiscount[]
  OutletAccess            OutletAccess[]
  ReceiptNumberCounter    ReceiptNumberCounter?
  users                   User[]
  DailyCashReconciliation DailyCashReconciliation[]
  ingredientProcesses             IngredientProcess[]
  IngredientProcessNumberCounter  IngredientProcessNumberCounter?
  ingredientAdjustments           IngredientAdjustment[]
  IngredientAdjustmentNumberCounter IngredientAdjustmentNumberCounter?
}

model OutletAccess {
  id       String @id @default(uuid())
  userId   String
  outletId String
  outlet   Outlet @relation(fields: [outletId], references: [id])
  user     User   @relation(fields: [userId], references: [id])

  @@unique([userId, outletId])
}

model User {
  id           String         @id @default(uuid())
  role         Role
  createdAt    DateTime       @default(now())
  password     String
  username     String         @unique
  userId       String         @unique
  outletId     String
  Billing      Billing[]
  orders       Order[]        @relation("WaiterOrders")
  OutletAccess OutletAccess[]
  outlet       Outlet         @relation(fields: [outletId], references: [id])
  ingredientProcesses         IngredientProcess[]
  ingredientAdjustments       IngredientAdjustment[]
}

model Ingredient {
  id                 String               @id @default(uuid())
  name               String
  unit               String
  stockQty           Float
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  outletId           String
  foodLinks          FoodIngredient[]
  outlet             Outlet               @relation(fields: [outletId], references: [id])
  IngredientStockLog IngredientStockLog[]
  sourceProcesses    IngredientProcess[]  @relation("SourceIngredient")
  targetProcesses    IngredientProcess[]  @relation("TargetIngredient")
  ingredientAdjustments IngredientAdjustment[]
}

model FoodIngredient {
  id           String     @id @default(uuid())
  foodId       String
  ingredientId String
  quantity     Float
  food         Food       @relation(fields: [foodId], references: [id])
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])

  @@unique([foodId, ingredientId])
}

model IngredientStockLog {
  id              String       @id @default(uuid())
  ingredientId    String
  quantity        Float
  type            StockLogType
  createdAt       DateTime     @default(now())
  note            String?
  transactionDate DateTime     @default(now())
  updatedAt       DateTime     @default(now())
  outletId        String
  orderId         String?
  ingredient      Ingredient   @relation(fields: [ingredientId], references: [id])
  order           Order?       @relation(fields: [orderId], references: [id])
  outlet          Outlet       @relation(fields: [outletId], references: [id])
}

model FoodCategory {
  id    String @id @default(uuid())
  name  String @unique
  foods Food[]
}

model Food {
  id             String           @id @default(dbgenerated("uuid_generate_v4()"))
  name           String
  available      Boolean          @default(true)
  createdAt      DateTime         @default(now())
  imageUrl       String?
  foodCategoryId String?
  outletId       String
  foodCategory   FoodCategory?    @relation(fields: [foodCategoryId], references: [id])
  outlet         Outlet           @relation(fields: [outletId], references: [id])
  FoodIngredient FoodIngredient[]
  options        FoodOption[]
  prices         FoodPrice[]
  orderItems     OrderItem[]

  @@unique([name, outletId])
}

model FoodOption {
  id                   String              @id @default(dbgenerated("uuid_generate_v4()"))
  name                 String
  extraPrice           Float               @default(0)
  foodId               String
  available            Boolean             @default(true)
  foodOptionCategoryId String?
  food                 Food                @relation(fields: [foodId], references: [id])
  foodOptionCategory   FoodOptionCategory? @relation(fields: [foodOptionCategoryId], references: [id])
  OrderItemOption      OrderItemOption[]

  @@unique([name, foodId])
}

model FoodOptionCategory {
  id            String       @id @default(uuid())
  name          String       @unique
  selectionType String
  minSelections Int          @default(0)
  maxSelections Int?
  quantityRule  String       @default("NONE")
  foodOptions   FoodOption[]
}

model FoodPrice {
  id          String    @id @default(dbgenerated("uuid_generate_v4()"))
  foodId      String
  orderTypeId String
  price       Float
  food        Food      @relation(fields: [foodId], references: [id])
  orderType   OrderType @relation(fields: [orderTypeId], references: [id])

  @@unique([foodId, orderTypeId])
}

model DiningTable {
  id        String   @id @default(uuid())
  number    Int
  createdAt DateTime @default(now())
  outletId  String
  outlet    Outlet   @relation(fields: [outletId], references: [id])
  orders    Order[]

  @@unique([number, outletId])
}

model OrderNumberCounter {
  id        String   @id @default(uuid())
  outletId  String   @unique
  current   Int      @default(0)
  createdAt DateTime @default(now())
  outlet    Outlet   @relation(fields: [outletId], references: [id])
}

model ReceiptNumberCounter {
  id        String   @id @default(uuid())
  outletId  String   @unique
  current   Int      @default(0)
  createdAt DateTime @default(now())
  outlet    Outlet   @relation(fields: [outletId], references: [id])
}

model OrderType {
  id                String              @id @default(uuid())
  name              String              @unique
  prices            FoodPrice[]
  orders            Order[]
  OrderTypeDiscount OrderTypeDiscount[]
}

model OrderTypeDiscount {
  id          String    @id @default(uuid())
  outletId    String
  orderTypeId String
  percentage  Float
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  orderType   OrderType @relation(fields: [orderTypeId], references: [id])
  outlet      Outlet    @relation(fields: [outletId], references: [id])

  @@unique([orderTypeId, outletId])
}

model Order {
  id                 String               @id @default(uuid())
  diningTableId      String?
  waiterId           String
  status             OrderStatus          @default(PENDING)
  createdAt          DateTime             @default(now())
  remark             String?
  subtotal           Float                @default(0)
  total              Float                @default(0)
  orderTypeId        String
  outletId           String
  orderNumber        String
  customerName       String?
  onlineCode         String?
  Billing            Billing?
  IngredientStockLog IngredientStockLog[]
  diningTable        DiningTable?         @relation(fields: [diningTableId], references: [id])
  orderType          OrderType            @relation(fields: [orderTypeId], references: [id])
  outlet             Outlet               @relation(fields: [outletId], references: [id])
  waiter             User                 @relation("WaiterOrders", fields: [waiterId], references: [id])
  items              OrderItem[]

  @@unique([outletId, orderNumber])
}

model OrderItem {
  id         String            @id @default(uuid())
  orderId    String
  foodId     String
  quantity   Int               @default(1)
  totalPrice Float             @default(0)
  unitPrice  Float             @default(0)
  createdAt  DateTime          @default(now())
  status     OrderItemStatus   @default(ACTIVE)
  food       Food              @relation(fields: [foodId], references: [id])
  order      Order             @relation(fields: [orderId], references: [id])
  options    OrderItemOption[]

  @@index([orderId])
}

model OrderItemOption {
  id          String          @id @default(uuid())
  orderItemId String
  optionId    String
  quantity    Int             @default(1)
  totalPrice  Float           @default(0)
  unitPrice   Float           @default(0)
  createdAt   DateTime        @default(now())
  status      OrderItemStatus @default(ACTIVE)
  option      FoodOption      @relation(fields: [optionId], references: [id])
  orderItem   OrderItem       @relation(fields: [orderItemId], references: [id])

  @@index([optionId])
}

model Billing {
  id            String        @id @default(uuid())
  orderId       String        @unique
  subtotal      Float
  tax           Float
  discount      Float
  total         Float
  amountPaid    Float
  changeGiven   Float
  paymentType   PaymentType
  paidAt        DateTime      @default(now())
  cashierId     String
  receiptNumber String
  remark        String?
  createdAt     DateTime      @default(now())
  outletId      String
  orderNumber   String
  status        PaymentStatus @default(PAID)
  cashier       User          @relation(fields: [cashierId], references: [id])
  order         Order         @relation(fields: [orderId], references: [id])
  outlet        Outlet        @relation(fields: [outletId], references: [id])

  @@unique([outletId, receiptNumber])
}

model DailyCashReconciliation {
  id                     String   @id @default(uuid())
  outletId               String
  date                   DateTime @map("report_date")
  previousDayBalance     Float    @default(0)
  cashDeposit            Float    @default(0)
  dailyCashRevenue       Float    @default(0)
  remainingBalance       Float    @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  paymentRemarks         Json?
  isLocked               Boolean  @default(false)
  submittedByCashierName String?
  adjustmentAmount       Float?   @default(0)
  outlet                 Outlet   @relation(fields: [outletId], references: [id])

  @@unique([outletId, date])
  @@index([date])
  @@map("daily_cash_reconciliation")
}

enum PaymentStatus {
  PAID
  VOID
}

enum OrderStatus {
  PENDING
  SERVED
  PAID
  CANCELED
  VOID
  COMPLETED
}

enum StockLogType {
  INBOUND
  DISCREPANCY
  OUTBOUND_NM
  OUTBOUND_BOSS
  OUTBOUND_STAFF
  TRANSFER_NAGOYA
  TRANSFER_SERAYA
  TRANSFER_BENGKONG
  TRANSFER_MALALAYANG
  TRANSFER_KLEAK
  TRANSFER_PANIKI
  TRANSFER_ITC
  VOID
  TRANSFER_MANTOS
  TRANSFER_MAUMBI
  TRANSFER_TUMINTING
  TRANSFER_17AGUSTUS
  TRANSFER_PERKAMIL
  PROCESS_IN
  PROCESS_OUT
  ADJUST_IN
  ADJUST_OUT
}

enum OrderItemStatus {
  ACTIVE
  CANCELED
}

enum PaymentType {
  CASH
  QRIS
  BANK_TRANSFER
  KASBON
  GRABFOOD
  SHOPEEFOOD
  GOFOOD
  FOC
}

enum Role {
  WAITER
  CHEF
  CASHIER
  ADMIN
  SUPERUSER
  OWNER
}

model IngredientProcess {
  id                 String     @id @default(uuid())
  processNo          String     // Running number (e.g. "0000001", padded to 7 digits)
  outletId           String
  sourceIngredientId String
  targetIngredientId String
  quantity           Float      // Quantity processed in pieces (1:1 ratio enforced)
  notes              String?
  processedById      String
  createdAt          DateTime   @default(now())

  // Relations
  outlet             Outlet     @relation(fields: [outletId], references: [id])
  sourceIngredient   Ingredient @relation("SourceIngredient", fields: [sourceIngredientId], references: [id])
  targetIngredient   Ingredient @relation("TargetIngredient", fields: [targetIngredientId], references: [id])
  processedBy        User       @relation(fields: [processedById], references: [id])
}

model IngredientProcessNumberCounter {
  id        String   @id @default(uuid())
  outletId  String   @unique
  current   Int      @default(0)
  createdAt DateTime @default(now())
  outlet    Outlet   @relation(fields: [outletId], references: [id])
}

model IngredientAdjustment {
  id                 String     @id @default(uuid())
  adjustmentNo       String     // Running number (e.g. "0000001", padded to 7 digits)
  outletId           String
  ingredientId       String
  type               String     // "IN" or "OUT"
  quantity           Float      
  notes              String?
  adjustedById       String
  createdAt          DateTime   @default(now())

  // Relations
  outlet             Outlet     @relation(fields: [outletId], references: [id])
  ingredient         Ingredient @relation(fields: [ingredientId], references: [id])
  adjustedBy         User       @relation(fields: [adjustedById], references: [id])
}

model IngredientAdjustmentNumberCounter {
  id        String   @id @default(uuid())
  outletId  String   @unique
  current   Int      @default(0)
  createdAt DateTime @default(now())
  outlet    Outlet   @relation(fields: [outletId], references: [id])
}
